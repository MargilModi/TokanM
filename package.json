{
  "name": "tokanm",
  "version": "1.0.0",
  "description": "ERC20 Token using Hardhat and OpenZeppelin",
  "scripts": {
    "postinstall": "node scripts/setup-compiler.js",
    "setup": "node scripts/setup-compiler.js",
    "compile": "hardhat compile",
